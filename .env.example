# Database
DATABASE_URL="postgresql://user:password@localhost:5432/talent_wharf?schema=public"

# JWT
JWT_SECRET="your-jwt-secret-change-this"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=development

# CORS - allowed origins (comma-separated)
# Include your web app URL and the Chrome extension ID
CORS_ORIGINS="http://localhost:5173,chrome-extension://your-extension-id"
